#!/usr/bin/env bash
# Pre-push: soft ratchet check (same as pre-commit — fast, no cargo build).
# Hard gates (clippy, docs, dead-code) run in CI via quality.yml.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
GATE_SCRIPT="$REPO_ROOT/scripts/quality-gate-check.sh"

if [ -f "$GATE_SCRIPT" ]; then
    echo ""
    echo "Running quality gate (soft ratchets) before push..."
    bash "$GATE_SCRIPT" --soft
else
    echo "WARNING: quality-gate-check.sh not found, skipping pre-push quality gate"
fi
